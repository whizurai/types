{
  "name": "@whizurai/types",
  "version": "1.0.0",
  "description": "TypeScript type definitions for Whizurai Platform APIs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./capabilities": {
      "types": "./dist/capabilities/index.d.ts",
      "import": "./dist/capabilities/index.js",
      "require": "./dist/capabilities/index.js"
    },
    "./capabilities/contextual-rerank": {
      "types": "./dist/capabilities/contextual-rerank.d.ts",
      "import": "./dist/capabilities/contextual-rerank.js",
      "require": "./dist/capabilities/contextual-rerank.js"
    },
    "./capabilities/contextual-rerank/schemas": {
      "types": "./dist/capabilities/contextual-rerank.schemas.d.ts",
      "import": "./dist/capabilities/contextual-rerank.schemas.js",
      "require": "./dist/capabilities/contextual-rerank.schemas.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "whizurai",
    "types",
    "typescript",
    "api"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/whizurai/types.git"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "zod": "^3.22.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "typescript": "^5.3.0",
    "zod": "^3.22.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  }
}
